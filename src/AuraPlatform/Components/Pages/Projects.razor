@page "/projects"
@using AuraPlatform.Models
@using AuraPlatform.Services
@inject ProjectStatusService StatusService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Architecture - CloudAura Portfolio</PageTitle>

<div class="projects-page">
    <h1 class="page-heading">Architecture</h1>
    <p class="page-sub">7 production systems — click any card for engineering details, architecture flows, and design decisions.</p>

    <div class="project-grid">
        @foreach (var status in statuses)
        {
            var project = status.Project;
            <div class="project-card" @onclick="() => Navigate(project.Id)">
                <!-- Header -->
                <div class="pc-header">
                    <div class="pc-id-row">
                        <span class="pc-id">@project.Id</span>
                        @if (!string.IsNullOrEmpty(project.Category))
                        {
                            <span class="pc-cat @GetCatCss(project.Category)">@project.Category</span>
                        }
                    </div>
                    <span class="pc-health @GetHealthCss(status.Health)">@status.Health</span>
                </div>

                <!-- Title -->
                <h3 class="pc-name">@project.Name</h3>
                <p class="pc-desc">@project.Description</p>

                <!-- Architecture mini-flow -->
                @if (project.ArchitectureFlow.Count > 0)
                {
                    <div class="pc-arch">
                        @for (var i = 0; i < Math.Min(project.ArchitectureFlow.Count, 5); i++)
                        {
                            @if (i > 0) { <span class="pc-arch-sep">&rarr;</span> }
                            <span class="pc-arch-step">@project.ArchitectureFlow[i]</span>
                        }
                        @if (project.ArchitectureFlow.Count > 5)
                        {
                            <span class="pc-arch-sep">&rarr;</span>
                            <span class="pc-arch-more">+@(project.ArchitectureFlow.Count - 5) more</span>
                        }
                    </div>
                }

                <!-- Footer -->
                <div class="pc-footer">
                    <span class="pc-stack">@project.Stack</span>
                    @if (status.ResponseTimeMs.HasValue)
                    {
                        <span class="pc-latency">@(status.ResponseTimeMs)ms</span>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private IReadOnlyList<ProjectStatus> statuses = Array.Empty<ProjectStatus>();

    protected override void OnInitialized()
    {
        RefreshStatuses();
        StatusService.OnStatusChanged += HandleStatusChanged;
    }

    private void HandleStatusChanged()
    {
        InvokeAsync(() =>
        {
            RefreshStatuses();
            StateHasChanged();
        });
    }

    private void RefreshStatuses()
    {
        statuses = StatusService.GetAllStatuses().Values.ToList();
    }

    private void Navigate(string projectId)
    {
        Navigation.NavigateTo($"projects/{projectId}");
    }

    private static string GetHealthCss(HealthState h) => h switch
    {
        HealthState.Healthy => "health-ok",
        HealthState.Degraded => "health-warn",
        HealthState.Unhealthy => "health-err",
        _ => "health-unk"
    };

    private static string GetCatCss(string c) => c switch
    {
        "AI" => "cat-ai",
        "Cloud" => "cat-cloud",
        "Infrastructure" => "cat-infra",
        _ => ""
    };

    public void Dispose()
    {
        StatusService.OnStatusChanged -= HandleStatusChanged;
    }
}
