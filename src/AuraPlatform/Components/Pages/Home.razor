@page "/"
@using AuraPlatform.Models
@using AuraPlatform.Services
@inject ProjectStatusService StatusService
@implements IDisposable

<PageTitle>CloudAura Portfolio</PageTitle>

<!-- Hero -->
<div class="hero">
    <h1 class="hero-title">I build AI-native cloud systems.</h1>
    <p class="hero-sub">@statuses.Count production services. Everything you see is live.</p>
    <div class="hero-tags">
        <span class="hero-tag ai">@aiCount AI Systems</span>
        <span class="hero-tag cloud">@cloudCount Cloud Platform</span>
        <span class="hero-tag infra">@infraCount Infrastructure</span>
    </div>
</div>

<!-- Summary bar -->
<div class="summary-bar">
    <div class="summary-item ok">
        <span class="summary-count">@healthyCount</span>
        <span class="summary-label">Healthy</span>
    </div>
    <div class="summary-item warn">
        <span class="summary-count">@degradedCount</span>
        <span class="summary-label">Degraded</span>
    </div>
    <div class="summary-item err">
        <span class="summary-count">@unhealthyCount</span>
        <span class="summary-label">Unhealthy</span>
    </div>
</div>

<!-- Services -->
<h3 class="section-title">Systems</h3>
<div class="row mt-3">
    @foreach (var status in statuses)
    {
        <div class="col-md-4 mb-3">
            <a href="projects/@status.Project.Id" class="text-decoration-none">
                <div class="card service-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <h5 class="card-title mb-0">@status.Project.Id</h5>
                                @if (!string.IsNullOrEmpty(status.Project.Category))
                                {
                                    <span class="category-tag @GetCategoryCss(status.Project.Category)">@status.Project.Category</span>
                                }
                            </div>
                            <span class="badge @GetBadgeClass(status.Health)">@status.Health</span>
                        </div>
                        <h6 class="card-subtitle text-muted">@status.Project.Name</h6>
                        <p class="card-text mt-2 small">@status.Project.Description</p>
                        @if (!string.IsNullOrEmpty(status.Project.Highlight))
                        {
                            <p class="card-highlight">@status.Project.Highlight</p>
                        }
                        <div class="d-flex justify-content-between small text-muted mt-auto">
                            <span>@status.Project.Stack</span>
                            @if (status.ResponseTimeMs.HasValue)
                            {
                                <span class="response-time">@(status.ResponseTimeMs)ms</span>
                            }
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@code {
    private IReadOnlyList<ProjectStatus> statuses = Array.Empty<ProjectStatus>();
    private int healthyCount;
    private int degradedCount;
    private int unhealthyCount;
    private int aiCount;
    private int cloudCount;
    private int infraCount;

    protected override void OnInitialized()
    {
        RefreshStatuses();
        StatusService.OnStatusChanged += HandleStatusChanged;
    }

    private void HandleStatusChanged()
    {
        InvokeAsync(() =>
        {
            RefreshStatuses();
            StateHasChanged();
        });
    }

    private void RefreshStatuses()
    {
        statuses = StatusService.GetAllStatuses().Values.ToList();
        healthyCount = statuses.Count(s => s.Health == HealthState.Healthy);
        degradedCount = statuses.Count(s => s.Health == HealthState.Degraded);
        unhealthyCount = statuses.Count(s => s.Health == HealthState.Unhealthy);
        aiCount = statuses.Count(s => s.Project.Category == "AI");
        cloudCount = statuses.Count(s => s.Project.Category == "Cloud");
        infraCount = statuses.Count(s => s.Project.Category == "Infrastructure");
    }

    private static string GetBadgeClass(HealthState health) => health switch
    {
        HealthState.Healthy => "bg-success",
        HealthState.Degraded => "bg-warning text-dark",
        HealthState.Unhealthy => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetCategoryCss(string category) => category switch
    {
        "AI" => "cat-ai",
        "Cloud" => "cat-cloud",
        "Infrastructure" => "cat-infra",
        _ => ""
    };

    public void Dispose()
    {
        StatusService.OnStatusChanged -= HandleStatusChanged;
    }
}
